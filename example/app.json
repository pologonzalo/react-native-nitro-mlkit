{
  "expo": {
    "name": "NitroMLKit Example",
    "slug": "nitro-mlkit-example",
    "version": "1.0.0",
    "scheme": "nitro-mlkit-example",
    "ios": {
      "bundleIdentifier": "com.nitromlkit.example",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nitromlkit.example",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "@nitro-mlkit/face-detection",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "639895f7-44ad-48d8-b234-2c87b0ab85ba"
      }
    },
    "owner": "black-sun-studios"
  }
}
