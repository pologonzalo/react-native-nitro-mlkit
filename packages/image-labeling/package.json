    "image-labeling",
    "image-classification",
    "nsfw-detection",
    "content-filter",
    "machine-learning",
    "on-device",
    "expo",
    "expo-plugin"
  ],
  "author": "pologonzalo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pologonzalo/react-native-nitro-mlkit",
    "directory": "packages/image-labeling"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76",
    "react-native-nitro-modules": ">=0.20"
  },
  "devDependencies": {
    "nitro-codegen": "*",
    "react-native-nitro-modules": "*",
    "typescript": "~5.9.0"
  },
  "files": [
    "src",
