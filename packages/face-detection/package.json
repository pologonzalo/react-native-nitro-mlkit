{
  "name": "@nitro-mlkit/face-detection",
  "version": "0.1.0-beta.0",
  "description": "High-performance on-device face detection for React Native — Google ML Kit + Nitro Modules (JSI). Native batch processing, face cropping, zero bridge overhead.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "codegen": "nitro-codegen",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "nitro",
    "mlkit",
    "face-detection",
    "machine-learning",
    "on-device",
    "expo",
    "expo-plugin"
  ],
  "author": "pologonzalo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pologonzalo/react-native-nitro-mlkit",
    "directory": "packages/face-detection"
  },
  "dependencies": {
    "@expo/config-plugins": "^55.0.0"
  },
  "peerDependencies": {
    "expo-modules-core": "*",
    "react": ">=18",
    "react-native": ">=0.76",
    "react-native-nitro-modules": ">=0.20"
  },
  "devDependencies": {
    "expo-modules-core": "*",
    "nitro-codegen": "*",
    "react-native-nitro-modules": "*",
    "typescript": "~5.9.0"
  },
  "files": [
    "src",
    "ios/**/*.swift",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "android/src",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "plugin",
    "nitrogen/generated",
    "*.podspec",
    "nitro.json",
    "app.plugin.js",
    "README.md",
    "LICENSE"
  ]
}
