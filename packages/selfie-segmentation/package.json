    "selfie-segmentation",
    "segmentation",
    "background-removal",
    "machine-learning",
    "on-device",
    "expo"
  ],
  "author": "pologonzalo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pologonzalo/react-native-nitro-mlkit",
    "directory": "packages/selfie-segmentation"
  },
  "peerDependencies": {
    "expo-modules-core": "*",
    "react": ">=18",
    "react-native": ">=0.76",
    "react-native-nitro-modules": ">=0.20"
  },
  "devDependencies": {
    "expo-modules-core": "*",
    "nitro-codegen": "*",
    "react-native-nitro-modules": "*",
    "typescript": "~5.9.0"
  },
  "files": [
    "src",
    "ios/**/*.swift",
    "android/src",
    "android/build.gradle",
    "android/CMakeLists.txt",
