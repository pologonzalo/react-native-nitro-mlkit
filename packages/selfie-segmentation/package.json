{
  "name": "@nitro-mlkit/selfie-segmentation",
  "version": "0.1.0-beta.0",
  "description": "High-performance on-device selfie segmentation for React Native — Google ML Kit + Nitro. Foreground/background mask, native batch, zero bridge overhead.",
